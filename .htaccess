Options -Indexes

# ── Redirect legacy .html requests to .php ───────────────────────────────
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)\.html$ $1.php [L,R=301]

# ── Pass Authorization header to PHP (required for CGI/FastCGI setups) ───
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ── Block direct browser access to sensitive PHP files ────────────────────
# FilesMatch compares against filename only (not path), so these match
# regardless of directory depth.
<FilesMatch "^(config|auth_helper|db_init|prompts)\.php$">
    Require all denied
</FilesMatch>

# ── Security headers ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
